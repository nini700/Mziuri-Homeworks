<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<AnchorPane prefHeight="400.0" prefWidth="500.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Davaleba1.Controller">
    <children>
        <Label layoutX="170.0" layoutY="30.0" text="აირჩიე შინაური ცხოველი">
            <font><Font size="18.0" /></font>
        </Label>

        <RadioButton fx:id="catRadio" layoutX="200.0" layoutY="90.0" text="კატა" />
        <RadioButton fx:id="dogRadio" layoutX="200.0" layoutY="120.0" text="ძაღლი" />
        <RadioButton fx:id="rabbitRadio" layoutX="200.0" layoutY="150.0" text="კურდღელი" />
        <RadioButton fx:id="birdRadio" layoutX="200.0" layoutY="180.0" text="ჩიტი" />

        <Label layoutX="150.0" layoutY="225.0" text="შინაური ცხოველის სახელი:" />
        <TextField fx:id="nameTextField" layoutX="150.0" layoutY="250.0" promptText="ex: Bunny" />

        <Button layoutX="200.0" layoutY="300.0" mnemonicParsing="false" onAction="#submit" text="Submit" />

        <Label fx:id="resultLabel" layoutX="80.0" layoutY="350.0">
            <font><Font size="14.0" /></font>
        </Label>
    </children>
</AnchorPane>