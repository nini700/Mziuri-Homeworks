<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<AnchorPane prefHeight="500.0" prefWidth="400.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="login.LoginController">
    <children>
        <Label layoutX="150.0" layoutY="20.0" text="Sign Up">
            <font><Font size="20.0" /></font>
        </Label>

        <Label layoutX="30.0" layoutY="65.0" text="Username:" />
        <TextField fx:id="signupUsername" layoutX="130.0" layoutY="60.0" promptText="username" />
        <Label layoutX="30.0" layoutY="105.0" text="Password:" />
        <TextField fx:id="signupPassword" layoutX="130.0" layoutY="100.0" promptText="password" />
        <Label layoutX="30.0" layoutY="145.0" text="Re-Password:" />
        <TextField fx:id="signupRePassword" layoutX="130.0" layoutY="140.0" promptText="re-enter password" />

        <Button layoutX="160.0" layoutY="185.0" mnemonicParsing="false" onAction="#signUp" text="Sign Up" />
        <Label fx:id="signupStatus" layoutX="80.0" layoutY="225.0" textFill="RED" />
        <Label layoutX="30.0" layoutY="255.0" text="─────────────────────────────" />
        <Label layoutX="160.0" layoutY="275.0" text="Login">
            <font><Font size="20.0" /></font>
        </Label>

        <Label layoutX="30.0" layoutY="320.0" text="Username:" />
        <TextField fx:id="loginUsername" layoutX="130.0" layoutY="315.0" promptText="username" />
        <Label layoutX="30.0" layoutY="360.0" text="Password:" />
        <TextField fx:id="loginPassword" layoutX="130.0" layoutY="355.0" promptText="password" />
        <Button layoutX="160.0" layoutY="395.0" mnemonicParsing="false" onAction="#login" text="Login" />
        <Label fx:id="loginStatus" layoutX="80.0" layoutY="435.0" textFill="GREEN" />
    </children>
</AnchorPane>