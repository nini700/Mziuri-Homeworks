<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.shape.Circle?>
<AnchorPane prefHeight="500.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Davaleba1.BallController">
    <children>

        <Button layoutX="283.0" layoutY="14.0" mnemonicParsing="false" onAction="#up" text="Up" />
        <Button layoutX="276.0" layoutY="440.0" mnemonicParsing="false" onAction="#down" text="Down" />
        <Button layoutX="14.0" layoutY="230.0" mnemonicParsing="false" onAction="#left" text="Left" />
        <Button layoutX="539.0" layoutY="230.0" mnemonicParsing="false" onAction="#right" text="Right" />

        <Button layoutX="14.0" layoutY="14.0" mnemonicParsing="false" onAction="#upLeft" text="↖" />
        <Button layoutX="539.0" layoutY="14.0" mnemonicParsing="false" onAction="#upRight" text="↗" />
        <Button layoutX="14.0" layoutY="440.0" mnemonicParsing="false" onAction="#downLeft" text="↙" />
        <Button layoutX="539.0" layoutY="440.0" mnemonicParsing="false" onAction="#downRight" text="↘" />

        <Button layoutX="240.0" layoutY="440.0" mnemonicParsing="false" onAction="#makeRed" text="Red" />


        <Button layoutX="320.0" layoutY="440.0" mnemonicParsing="false" onAction="#changeColor" text="Color" />

        <Circle fx:id="myCircle" fill="#802e7c" layoutX="300.0" layoutY="230.0" radius="30.0" stroke="BLACK" strokeType="INSIDE" />
    </children>
</AnchorPane>